<% layout("layouts/boilerplate") %>

    <div class="row">
        <div class="col-8 offset-2">
            <!-- <br><br> -->
    <h3>Create a new Listings :</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
         <div class="mb-3">
          <label for="title" class="form-label">Title :</label>
          <input name="listing[title]" placeholder="Add a catchy title" class="form-control" required>   <!-- required means  titel hone he chahiye-->
          <div class="valid-feedback">Tittle looks good!</div>  <!--Using boostrap add suucess and failure for from-->
         </div>
         
          <div class="mb-3">
            <label for="description" class="form-label" >Description :</label>
          <textarea type="text" name="listing[description]" placeholder="Enter description" class="form-control" required></textarea>
          <div class="invalid-feedback">Please enter a short descriptions!</div>
          </div>

          <!-- <div class="mb-3">
          <label for="image" class="form-label">Image :</label>
          <input type="text" name="listing[image]" placeholder="Enter image URL/LINK" class="form-control" required>
         </div> -->
         
               <!--this is image are upload user not a link-->
         <div class="mb-3">
          <label for="image" class="form-label">Uploads Image :</label>
          <input type="file" name="listing[image]" class="form-control" required>
         </div>
 
         <div class="row">
              <div class="mb-3 col-md-4">
              <label for="price" class="form-label">Price :</label>
              <input name="listing[price]" placeholder="1200" class="form-control" type="number" required>
              <div class="invalid-feedback">Price should be valide !</div> 
              </div>

              <div class="mb-3 col-md-8">
              <label for="country" class="form-label">Country :</label>
              <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
              <div class="invalid-feedback">Country should be valide !</div> 
              </div>
         </div>
         
          
         <div class="mb-3">
          <label for="location" class="form-label">Location :</label>
          <input type="text" name="listing[location]" placeholder="Jaipur,Rajasthan" class="form-control" required>
          <div class="invalid-feedback">Location should be valide !</div>
         </div>

         
          <button class="btn btn-dark add-btn my-3">Add</button>
          
    </form>
    </div>
</div>
