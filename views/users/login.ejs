<% layout("layouts/boilerplate") %>

<div class="row mt-3">
    <h1  class="col-6 offset-3">Login</h1>
  <div class="col-6 offset-3">

<form action="/login" method="POST" class="needs-validation" novalidate>
     <div class="mb-3">
          <label for="username" class="form-label">Username </label>
          <input name="username" class="form-control" type="text" id="username" required>   <!-- required means  titel hone he chahiye-->
          <div class="valid-feedback">Looks good!</div>  <!--Using boostrap add suucess and failure for from-->
         </div>

         <div class="mb-3">
          <label for="password" class="form-label">Password </label>
          <input name="password" class="form-control" type="text" id="password" required>   <!-- required means  titel hone he chahiye-->
         </div>

         <button class="btn btn-success">Login</button>

</form>

</div>    
</div>