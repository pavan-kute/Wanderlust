<% layout("layouts/boilerplate") %>

<section class="form-shell auth-shell">
  <div class="form-header">
    <span class="eyebrow">Welcome back</span>
    <h1>Log in to WanderLust</h1>
    <p>Pick up where you left off and manage your stays in one place.</p>
  </div>

<form action="/login" method="POST" class="needs-validation" novalidate>
     <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input name="username" class="form-control" type="text" id="username" required>
          <div class="valid-feedback">Looks good!</div>
         </div>

         <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input name="password" class="form-control" type="password" id="password" required>
         </div>

         <button class="btn nav-solid auth-submit">Log in</button>

</form>
</section>
