<% layout("layouts/boilerplate") %>

<section class="form-shell auth-shell">
  <div class="form-header">
    <span class="eyebrow">Join the community</span>
    <h1>Sign up on WanderLust</h1>
    <p>Create your account to save stays, post listings, and start traveling smarter.</p>
  </div>

<form action="/signup" method="POST" class="needs-validation" novalidate>
     <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input name="username" class="form-control" type="text" id="username" required>
          <div class="valid-feedback">Looks good!</div>
         </div>

         <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input name="email" class="form-control" type="email" id="email" required>
         </div>

         <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input name="password" class="form-control" type="password" id="password" required>
         </div>

         <button class="btn nav-solid auth-submit">Create account</button>

</form>
</section>
